// ─────────────────────────────────────────────────────────────────────────────
// PRISMA SCHEMA — Sistema Corporativo de Reconhecimento
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  COLLABORATOR
  MANAGER
  DIRECTOR
  ADMIN
}

enum ComplimentStatus {
  PENDENTE_APROVACAO
  PENDENTE_AVALIACAO
  REJEITADO
  DEVOLVIDO_PARA_AJUSTE
  AVALIADO
}

enum ApprovalAction {
  APPROVED
  REJECTED
  RETURNED
}

enum MedalType {
  BRONZE
  SILVER
  GOLD
  SPECIAL
}

enum TrainingType {
  TRAINING
  CONSULTANCY
  COURSE
}

enum NotificationType {
  COMPLIMENT_APPROVED
  COMPLIMENT_REJECTED
  COMPLIMENT_RETURNED
  COMPLIMENT_EVALUATED
  COMPLIMENT_REEVALUATED
  NEW_PENDING_APPROVAL
  NEW_PENDING_EVALUATION
  DEADLINE_WARNING
  GENERAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  RETURN_FOR_ADJUSTMENT
  EVALUATE
  REEVALUATE
  LOGIN
  LOGOUT
  ACTIVATE_ACCOUNT
  DEACTIVATE_ACCOUNT
  RESET_PASSWORD
}

enum DeadlineType {
  REGISTRATION
  APPROVAL
  EVALUATION
  CENTRAL_EVALUATION
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(200)
  email         String   @unique @db.VarChar(255)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  role          Role     @default(COLLABORATOR)
  isActive      Boolean  @default(true) @map("is_active")
  emailVerified Boolean  @default(false) @map("email_verified")
  areaId        String?  @map("area_id")
  avatarUrl     String?  @map("avatar_url") @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  area                    Area?                    @relation("AreaCollaborators", fields: [areaId], references: [id])
  managedAreas            Area[]                   @relation("AreaManagers")
  directedAreas           Area[]                   @relation("AreaDirectors")
  submittedCompliments    Compliment[]             @relation("SubmittedCompliments")
  receivedCompliments     Compliment[]             @relation("ReceivedCompliments")
  complimentApprovals     ComplimentApproval[]
  complimentEvaluations   ComplimentEvaluation[]
  complimentReevaluations ComplimentReevaluation[]
  submittedTrainings      Training[]               @relation("SubmittedTrainings")
  receivedTrainings       Training[]               @relation("ReceivedTrainings")
  notifications           Notification[]
  auditLogs               AuditLog[]
  verificationCodes       VerificationCode[]

  @@index([role])
  @@index([areaId])
  @@index([email])
  @@map("users")
}

model Area {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(200)
  managerId  String?  @map("manager_id")
  directorId String?  @map("director_id")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  manager       User?  @relation("AreaManagers", fields: [managerId], references: [id])
  director      User?  @relation("AreaDirectors", fields: [directorId], references: [id])
  collaborators User[] @relation("AreaCollaborators")

  @@index([managerId])
  @@index([directorId])
  @@map("areas")
}

model Compliment {
  id             String           @id @default(uuid())
  insured        String           @db.VarChar(300)
  receivedAt     DateTime         @map("received_at") @db.Date
  branch         String           @db.VarChar(200)
  reason         String           @db.Text
  claimHistory   String           @map("claim_history") @db.Text
  collaboratorId String           @map("collaborator_id")
  submittedById  String           @map("submitted_by_id")
  status         ComplimentStatus @default(PENDENTE_APROVACAO)
  attachmentUrl  String?          @map("attachment_url") @db.VarChar(500)
  attachmentName String?          @map("attachment_name") @db.VarChar(255)
  attachmentType String?          @map("attachment_type") @db.VarChar(50)
  quarter        Int              @default(1)
  year           Int
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  collaborator    User                     @relation("ReceivedCompliments", fields: [collaboratorId], references: [id])
  submittedBy     User                     @relation("SubmittedCompliments", fields: [submittedById], references: [id])
  approvals       ComplimentApproval[]
  evaluations     ComplimentEvaluation[]
  reevaluations   ComplimentReevaluation[]
  notifications   Notification[]

  @@index([collaboratorId])
  @@index([submittedById])
  @@index([status])
  @@index([year, quarter])
  @@index([createdAt])
  @@map("compliments")
}

model ComplimentApproval {
  id           String         @id @default(uuid())
  complimentId String         @map("compliment_id")
  managerId    String         @map("manager_id")
  action       ApprovalAction
  observation  String?        @db.Text
  createdAt    DateTime       @default(now()) @map("created_at")

  compliment Compliment @relation(fields: [complimentId], references: [id], onDelete: Cascade)
  manager    User       @relation(fields: [managerId], references: [id])

  @@index([complimentId])
  @@index([managerId])
  @@map("compliment_approvals")
}

model ComplimentEvaluation {
  id            String    @id @default(uuid())
  complimentId  String    @unique @map("compliment_id")
  directorId    String    @map("director_id")
  medal         MedalType
  justification String    @db.Text
  comment       String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  compliment Compliment @relation(fields: [complimentId], references: [id], onDelete: Cascade)
  director   User       @relation(fields: [directorId], references: [id])

  @@index([directorId])
  @@index([medal])
  @@map("compliment_evaluations")
}

model ComplimentReevaluation {
  id            String    @id @default(uuid())
  complimentId  String    @map("compliment_id")
  directorId    String    @map("director_id")
  previousMedal MedalType @map("previous_medal")
  newMedal      MedalType @map("new_medal")
  reason        String    @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  compliment Compliment @relation(fields: [complimentId], references: [id], onDelete: Cascade)
  director   User       @relation(fields: [directorId], references: [id])

  @@index([complimentId])
  @@index([directorId])
  @@map("compliment_reevaluations")
}

model Training {
  id             String       @id @default(uuid())
  insured        String       @db.VarChar(300)
  date           DateTime     @db.Date
  type           TrainingType
  branch         String       @db.VarChar(200)
  collaboratorId String       @map("collaborator_id")
  submittedById  String       @map("submitted_by_id")
  attachmentUrl  String?      @map("attachment_url") @db.VarChar(500)
  attachmentName String?      @map("attachment_name") @db.VarChar(255)
  attachmentType String?      @map("attachment_type") @db.VarChar(50)
  quarter        Int          @default(1)
  year           Int
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  collaborator User @relation("ReceivedTrainings", fields: [collaboratorId], references: [id])
  submittedBy  User @relation("SubmittedTrainings", fields: [submittedById], references: [id])

  @@index([collaboratorId])
  @@index([type])
  @@index([year, quarter])
  @@index([createdAt])
  @@map("trainings")
}

model Notification {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  type          NotificationType
  title         String           @db.VarChar(255)
  message       String           @db.Text
  isRead        Boolean          @default(false) @map("is_read")
  referenceId   String?          @map("reference_id")
  referenceType String?          @map("reference_type") @db.VarChar(50)
  createdAt     DateTime         @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  compliment Compliment? @relation(fields: [referenceId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  userName      String      @map("user_name") @db.VarChar(200)
  userRole      String      @map("user_role") @db.VarChar(50)
  action        AuditAction
  entityType    String      @map("entity_type") @db.VarChar(100)
  entityId      String?     @map("entity_id")
  previousValue Json?       @map("previous_value")
  newValue      Json?       @map("new_value")
  ipAddress     String?     @map("ip_address") @db.VarChar(45)
  userAgent     String?     @map("user_agent") @db.VarChar(500)
  createdAt     DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Deadline {
  id        String       @id @default(uuid())
  type      DeadlineType @unique
  days      Int
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@map("deadlines")
}

model VerificationCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  code      String    @db.Char(6)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@map("verification_codes")
}
